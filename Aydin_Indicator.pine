//@version=6
indicator(title="Aydın Ultimate İndikatörü", shorttitle="Aydın Ult.", overlay=false)

// =========================================================================
// 🎛️ KONTROL PANELİ (MANUEL AÇ/KAPAT BUTONLARI)
// =========================================================================
grp_vsa = "1. VSA Hacim Mumları"
show_vsa = input.bool(true, "🟢 VSA Hacim Mumlarını Göster", group=grp_vsa)

grp_rsibands = "2. RSI Bantları (Ana Grafik)"
show_rsibands = input.bool(true, "🟢 Ana Grafik RSI Bantlarını Göster", group=grp_rsibands)

grp_mtf = "3. MTF Sinyaller (AL/SAT/FBB)"
show_mtfsig = input.bool(true, "🟢 Sinyalleri ve Etiketleri Göster", group=grp_mtf)
tf_al = input.timeframe("", "Al Sinyali Zaman Dilimi", group=grp_mtf)
tf_sat = input.timeframe("", "Sat Sinyali Zaman Dilimi", group=grp_mtf)
tf_fbb = input.timeframe("", "FBB Sinyali Zaman Dilimi", group=grp_mtf)

grp_kama = "4. KAMA & SuperTrend"
show_kama = input.bool(true, "🟢 KAMA & SuperTrend Göster", group=grp_kama)

grp_fib = "5. Auto Fibs (Y, M, W)"
show_fib = input.bool(true, "🟢 Auto Fibs Göster", group=grp_fib)

grp_osc = "6. Alt Pencere Osilatörleri"
show_rsi = input.bool(true, "🟢 Standart RSI Göster", group=grp_osc)
show_stoch = input.bool(true, "🟢 StochRSI Göster", group=grp_osc)

// =========================================================================
// --- 1. VSA HACİM MUM BOYAMA EKLENTİSİ ---
// =========================================================================
volMA = ta.rma(volume, 20)
ultraHighVolumeMin = volMA * 2.2
volUltraHigh = volume >= ultraHighVolumeMin
[span_1](start_span)barcolor(show_vsa and volUltraHigh ? color.purple : na)[span_1](end_span)

// =========================================================================
// --- 2. ANA GRAFİK RSI BANTLARI (OVERLAY) ---
// =========================================================================
ep = 2 * 14 - 1
auc = ta.ema(math.max(close - close[1], 0), ep)
adc = ta.ema(math.max(close[1] - close, 0), ep)
[span_2](start_span)[span_3](start_span)x1 = 13 * (adc * 70 / 30 - auc)[span_2](end_span)[span_3](end_span)
[span_4](start_span)[span_5](start_span)bU = x1 >= 0 ? close + x1 : close + x1 * 30 / 70[span_4](end_span)[span_5](end_span)
x2 = 13 * (adc * 30 / 70 - auc)
[span_6](start_span)[span_7](start_span)bL = x2 >= 0 ? close + x2 : close + x2 * 70 / 30[span_6](end_span)[span_7](end_span)

plot(show_rsibands ? bU : na, "RSI Üst Bandı", color=color.red, linewidth=2, force_overlay=true)
plot(show_rsibands ? bL : na, "RSI Alt Bandı", color=color.green, linewidth=2, force_overlay=true)

// =========================================================================
// --- 3. MTF AL/SAT SİNYALLERİ ---
// =========================================================================
f_sig() =>
    [st, d] = ta.supertrend(3.0, 21)
    float a = na
    [span_8](start_span)[span_9](start_span)ns = math.abs(close - close[21])[span_8](end_span)[span_9](end_span)
    nn = math.sum(math.abs(close - close[1]), 21)
    [span_10](start_span)a := nz(a[1]) + math.pow((nn != 0 ? ns / nn : 0) * 0.6015 + 0.0645, 2) * (close - nz(a[1]))[span_10](end_span)
    d > 0 and ta.crossunder(st, a) ? 1 : d < 0 and ta.crossover(st, a) ? -[span_11](start_span)[span_12](start_span)1 : 0[span_11](end_span)[span_12](end_span)

calc_sig() =>
    bot = ta.vwma(hlc3, 200) - (3.0 * ta.stdev(hlc3, 200))
    bs = math.abs(close - open) > (ta.atr(200) * 0.1)
    br = close < open
    bl = close < bot
    (br and bl and bs) and (br[1] and bl[1] and bs[1])

get_custom_tf_signal(string tf, string sigType) =>
    bool sig = false
    if tf == "" or timeframe.in_seconds(tf) == timeframe.in_seconds(timeframe.period)
        if sigType == "AL"
            [span_13](start_span)[span_14](start_span)sig := f_sig() == 1[span_13](end_span)[span_14](end_span)
        else if sigType == "SAT"
            sig := f_sig() == -1
        else if sigType == "FBB"
            sig := calc_sig()
    [span_15](start_span)else if timeframe.in_seconds(tf) > timeframe.in_seconds(timeframe.period)[span_15](end_span)
        sig := request.security(syminfo.tickerid, tf, sigType == "AL" ? f_sig() == 1 : sigType == "SAT" ? f_sig() == -1 : calc_sig(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    else
        arr = request.security_lower_tf(syminfo.tickerid, tf, sigType == "AL" ? f_sig() == 1 : sigType == "SAT" ? f_sig() == -1 : calc_sig())
        sig := array.size(arr) > 0 and array.includes(arr, true)
    sig

al_sig = get_custom_tf_signal(tf_al, "AL")
sat_sig = get_custom_tf_signal(tf_sat, "SAT")
signal_exists = get_custom_tf_signal(tf_fbb, "FBB")

plotshape(show_mtfsig and al_sig, "Al", shape.triangleup, location.belowbar, color.green, size=size.tiny, force_overlay=true)
[span_16](start_span)plotshape(show_mtfsig and sat_sig, "Sat", shape.triangledown, location.abovebar, color.red, size=size.tiny, force_overlay=true)[span_16](end_span)
plotshape(show_mtfsig and signal_exists, "AL_FBB", shape.labelup, location.belowbar, color.orange, size=size.tiny, force_overlay=true)

// MTF Etiket Mantığı
[span_17](start_span)al_1d = get_custom_tf_signal("1D", "AL")[span_17](end_span)
sat_1d = get_custom_tf_signal("1D", "SAT")
fbb_1d = get_custom_tf_signal("1D", "FBB")
al_4h = get_custom_tf_signal("240", "AL")
sat_4h = get_custom_tf_signal("240", "SAT")
fbb_4h = get_custom_tf_signal("240", "FBB")
al_1h = get_custom_tf_signal("60", "AL")
sat_1h = get_custom_tf_signal("60", "SAT")
fbb_1h = get_custom_tf_signal("60", "FBB")

new_sig = al_1d ? "1D: AL" : sat_1d ? "1D: SAT" : fbb_1d ? "1D: FBB" : al_4h ? "4h: AL" : sat_4h ? "4h: SAT" : fbb_4h ? "4h: FBB" : al_1h ? "1h: AL" : sat_1h ? "1h: SAT" : fbb_1h ? [span_18](start_span)"1h: FBB" : ""[span_18](end_span)
[span_19](start_span)new_col = al_1d ? color.green : sat_1d ? color.red : fbb_1d ? color.orange : al_4h ? color.green : sat_4h ? color.red : fbb_4h ? color.orange : al_1h ? color.green : sat_1h ? color.red : fbb_1h ? color.orange : na[span_19](end_span)

var string latest_sig_text = ""
var color latest_sig_color = na
if new_sig != "" and show_mtfsig
    latest_sig_text := new_sig
    latest_sig_color := new_col
    [span_20](start_span)alert(syminfo.ticker + "-> " + latest_sig_text, alert.freq_once_per_bar)[span_20](end_span)

var label sig_label = label.new(bar_index, close, "", style=label.style_label_left)
if barstate.islast and show_mtfsig
    label.set_xy(sig_label, latest_sig_text != "" ? bar_index + 3 : bar_index, latest_sig_text != "" ? close : na)
    label.set_text(sig_label, latest_sig_text)
    label.set_color(sig_label, color.new(latest_sig_color, 80))
    label.set_textcolor(sig_label, latest_sig_color)

// =========================================================================
// --- 4. KAMA & SUPERTREND (ANA GRAFİK) ---
// =========================================================================
diff = math.abs(close - close[1])
[span_21](start_span)ER = math.sum(diff, 21) != 0 ? math.abs(close - close[21]) / math.sum(diff, 21) : 0[span_21](end_span)
sc_kama = math.pow(ER * (0.666 - 0.0645) + 0.0645, 2)
float kama = 0.0
kama := nz(kama[1], close) + sc_kama * (close - nz(kama[1], close))
[st_main, dir_main] = ta.supertrend(3.0, 21)

[span_22](start_span)plot(show_kama ? kama : na, 'KAMA', color=color.blue, linewidth=2, force_overlay=true)[span_22](end_span)
stPlot = plot(show_kama ? st_main : na, 'ST', dir_main < 0 ? color.green : color.red, linewidth=2, style=plot.style_linebr, force_overlay=true)
midPlot = plot(show_kama ? (open + close) / 2 : na, display=display.none, force_overlay=true)
fill(midPlot, stPlot, color=show_kama ? (dir_main < 0 ? color.new(color.green, 90) : color.new(color.red, 90)) : na)

// =========================================================================
// --- 5. AUTO FIBS (YILLIK, AYLIK, HAFTALIK) ---
// =========================================================================
// Performans için sadece haftalığı baz aldım, dilediğinde M ve Y eklenebilir. 
[span_23](start_span)[wphigh, wplow, wpclose] = request.security(syminfo.tickerid, 'W', [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)[span_23](end_span)
wpivot = (wphigh + wplow + wpclose) / 3
wr1 = wpivot + (wphigh - wplow) * 0.382
[span_24](start_span)ws1 = wpivot - (wphigh - wplow) * 0.382[span_24](end_span)
// Çizgileri ekrana basma (Sadece show_fib aktifse)
plot(show_fib ? wpivot : na, title="W Pivot", color=color.blue, style=plot.style_linebr, linewidth=1, force_overlay=true)
plot(show_fib ? wr1 : na, title="W R1", color=color.red, style=plot.style_linebr, linewidth=1, force_overlay=true)
plot(show_fib ? ws1 : na, title="W S1", color=color.green, style=plot.style_linebr, linewidth=1, force_overlay=true)

// =========================================================================
// --- 6. ALT PENCERE: RSI & STOCHRSI ---
// =========================================================================
// Standart RSI
up = ta.rma(math.max(ta.change(close), 0), 14)
down = ta.rma(-math.min(ta.change(close), 0), 14)
rsi_val = down == 0 ? 100 : up == 0 ? [span_25](start_span)0 : 100 - 100 / (1 + up / down)[span_25](end_span)
plot(show_rsi ? rsi_val : na, color=color.fuchsia, linewidth=2, title='RSI')
band1 = hline(70, color=color.gray, linestyle=hline.style_dotted)
band0 = hline(30, color=color.gray, linestyle=hline.style_dotted)

// StochRSI
rsi1 = ta.rsi(close, 14)
[span_26](start_span)k = ta.sma(ta.stoch(rsi1, rsi1, rsi1, 14), 3)[span_26](end_span)
d = ta.sma(k, 3)
plot(show_stoch ? k : na, color=color.blue, title='%K')
plot(show_stoch ? d : na, color=color.orange, title='%D')
h0 = hline(80, color=color.gray, linestyle=hline.style_dotted)
h1 = hline(20, color=color.gray, linestyle=hline.style_dotted)

// İşaretleyiciler (Markers)
plotshape(show_stoch and k <= 0, title='Dip Seviye (0)', style=shape.diamond, location=location.bottom, color=color.blue, size=size.tiny)
[span_27](start_span)plotshape(show_stoch and k >= 99, title='Tepe Seviye (99-100)', style=shape.diamond, location=location.top, color=color.orange, size=size.tiny)[span_27](end_span)
